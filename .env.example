# IA (elige UNA vía; si pones las dos, se usa Gemini primero)
# Opción recomendada — gratis con límites: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional: modelos (por defecto gemini-1.5-flash y text-embedding-004)
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_EMBED_MODEL=text-embedding-004

# Alternativa de pago: OpenAI
# OPENAI_API_KEY=sk-...

# Misma clave: entrenamiento (API training), extraer de imágenes, y **alta de artistas** (POST /api/artists/register con cabecera x-admin-secret)
ADMIN_SECRET=pon-aqui-una-clave-larga-y-secreta

# NextAuth (sesión de artistas): genera con `openssl rand -base64 32`
# En Vercel: obligatorio. Sin esto, middleware y layout peta con "server-side exception".
NEXTAUTH_SECRET=
# URL pública: en Vercel pon https://<tu-proyecto>.vercel.app (o tu dominio)
NEXTAUTH_URL=http://localhost:3000

# Firebase: una de las dos (ver README)
# Cuenta de servicio (JSON) en UNA sola línea, entre comillas, con comillas internas escapadas (\"), o pega un .json mínimo en un solo renglón
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# O ruta a un archivo .json de la cuenta de servicio (muy útil en local)
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/al/serviceAccount.json

FIREBASE_SERVICE_ACCOUNT_JSON=
